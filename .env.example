# ─── Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in values
# Never commit .env to version control

# ── Frontend ────────────────────────────────────────────────────────────
VITE_API_URL=https://data.brandcentral.in/api
VITE_SOCKET_URL=https://data.brandcentral.in

# ── Backend Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (SQL Server) ──────────────────────────────────────────────
DB_HOST=your-db-host.database.windows.net
DB_PORT=1433
DB_NAME=RetailOps
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# ── Amazon Creators API (LiveSync) ─────────────────────────────────────
LIVE_SYNC_CLIENT_ID=your_client_id
LIVE_SYNC_CLIENT_SECRET=your_client_secret
LIVE_SYNC_PARTNER_TAG=your_partner_tag
LIVE_SYNC_MARKETPLACE=www.amazon.in
LIVE_SYNC_ENABLED=true
LIVE_SYNC_SCHEDULE_TIME=06:00

# ── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=developer@brandcentral.in
SMTP_PASSWORD=your_app_password
SMTP_FROM="Brand Central <developer@brandcentral.in>"

# ── Application URLs ───────────────────────────────────────────────────
FRONTEND_URL=https://data.brandcentral.in
DASHBOARD_URL=https://data.brandcentral.in
APP_URL=https://data.brandcentral.in

# ── Automation ──────────────────────────────────────────────────────────
AUTOMATION_ENABLED=true
AUTOMATION_SCHEDULE_TIME=02:00
AUTOMATION_AMAZON_ENABLED=true
AUTOMATION_AJIO_ENABLED=false

# ── Security ────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# ── Cometchat (Optional) ───────────────────────────────────────────────
# REACT_APP_COMETCHAT_APP_ID=
# REACT_APP_COMETCHAT_AUTH_KEY=

# ── Vercel (Optional) ──────────────────────────────────────────────────
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
