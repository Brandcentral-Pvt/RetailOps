# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# SQL Server (primary database)
DB_USER=
DB_PASSWORD=
DB_SERVER=
DB_NAME=retailops
DB_PORT=1433
DB_POOL_MAX=50
DB_POOL_MIN=5

# JWT Authentication
JWT_SECRET=
JWT_REFRESH_SECRET=

# Market Sync
MARKET_SYNC_USERNAME=
MARKET_SYNC_PASSWORD=
MARKET_SYNC_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI Services (optional)
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
NIM_API_KEY=

# Octoparse (optional)
OCTOPARSE_API_KEY=
