# ─── Backend Environment Variables ──────────────────────────────────────
# Copy to backend/.env and fill in values

# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (SQL Server) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_NAME=RetailOps
DB_USER=sa
DB_PASSWORD=your_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# ── Amazon Creators API (LiveSync) ─────────────────────────────────────
LIVE_SYNC_CLIENT_ID=your_client_id
LIVE_SYNC_CLIENT_SECRET=your_client_secret
LIVE_SYNC_PARTNER_TAG=your_partner_tag
LIVE_SYNC_MARKETPLACE=www.amazon.in
LIVE_SYNC_ENABLED=true
LIVE_SYNC_SCHEDULE_TIME=06:00
LIVE_SYNC_CONCURRENCY=1

# ── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=developer@brandcentral.in
SMTP_PASSWORD=your_app_password
SMTP_FROM="Brand Central <developer@brandcentral.in>"

# ── Application URLs ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173
APP_URL=http://localhost:5173

# ── Automation ──────────────────────────────────────────────────────────
AUTOMATION_ENABLED=true
AUTOMATION_SCHEDULE_TIME=02:00
AUTOMATION_AMAZON_ENABLED=true
AUTOMATION_AJIO_ENABLED=false

# ── Security ────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Octoparse (Optional) ───────────────────────────────────────────────
# OCTOPARSE_API_KEY=
# OCTOPARSE_BASE_URL=
